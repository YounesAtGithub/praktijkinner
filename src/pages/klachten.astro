---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Container from '../components/Container.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Klachten en geschillen — Praktijk Inner">
  <Header brand="Praktijk Inner" ctaLabel="Kennismaken" ctaHref="/contact" />

  <main class="py-16">
    <Container>
      <div class="mx-auto max-w-3xl">

        <h1 class="font-serif text-5xl leading-tight">Klachten- en geschillencommissie</h1>

        <!-- Disclaimer -->
        <div class="mt-6 rounded-2xl bg-yellow-50 p-5 ring-1 ring-yellow-200 text-sm text-yellow-900">
          <strong>Let op:</strong> De inhoud van deze pagina is nog niet definitief en dient uitsluitend ter demonstratie.
        </div>

        <div class="mt-10 space-y-10 text-ink/80 leading-relaxed">

          <section>
            <h2 class="font-serif text-2xl">1. Inleiding</h2>
            <p class="mt-4">
              Praktijk Inner hecht waarde aan een zorgvuldige omgang met klachten.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-2xl">2. Interne klachtenprocedure</h2>
            <p class="mt-4">
              Indien u een klacht heeft, wordt u verzocht deze eerst bespreekbaar te maken binnen de praktijk.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-2xl">3. Externe klachtenregeling</h2>
            <p class="mt-4">
              Indien een klacht niet intern kan worden opgelost, kunt u zich wenden tot een externe klachtenfunctionaris.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-2xl">4. Geschillencommissie</h2>
            <p class="mt-4">
              Indien nodig kan een geschil worden voorgelegd aan een erkende geschillencommissie.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-2xl">5. Contact</h2>
            <p class="mt-4">
              Voor vragen of klachten kunt u contact opnemen via 
              <a href="mailto:info@praktijkinner.nl" class="underline">info@praktijkinner.nl</a>.
            </p>
          </section>

        </div>

      </div>
    </Container>
  </main>

  <Footer />
</BaseLayout>